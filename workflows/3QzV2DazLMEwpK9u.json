      "parameters": {
        "jsCode": "const adAttrs = $('Code: Build AD user attributes').first().json;\nconst existing = $('LDAP: Get current DN (enabled)').first().json;\n\nfunction valueOrExisting(submitted, existingVal) {\n  const v = String(submitted ?? '').trim();\n  if (v !== '') return v;\n  const e = String(existingVal ?? '').trim();\n  return e !== '' ? e : ' ';\n}\n\nconst finalTitle           = valueOrExisting(adAttrs.title, existing.title);\nconst finalCompany         = valueOrExisting(adAttrs.company, existing.company);\nconst finalStreetAddress   = valueOrExisting(adAttrs.streetAddress, existing.streetAddress);\nconst finalL               = valueOrExisting(adAttrs.l, existing.l);\nconst finalSt              = valueOrExisting(adAttrs.st, existing.st);\nconst finalPostalCode      = valueOrExisting(adAttrs.postalCode, existing.postalCode);\nconst finalTelephoneNumber = valueOrExisting(adAttrs.telephoneNumber, existing.telephoneNumber);\nconst finalMail            = valueOrExisting(adAttrs.mail, existing.mail);\n\nconst optionalFieldDefs = [\n  { id: 'pager',   value: adAttrs.pager },\n  { id: 'ipPhone', value: adAttrs.ipPhone },\n  { id: 'info',    value: adAttrs.info },\n];\nconst optionalReplace = optionalFieldDefs.filter(f => String(f.value ?? '').trim() !== '');\nconst hasOptional = optionalReplace.length > 0;\n\nreturn [{\n  json: {\n    ...adAttrs,\n    finalTitle, finalCompany, finalStreetAddress, finalL, finalSt,\n    finalPostalCode, finalTelephoneNumber, finalMail,\n    optionalReplace, hasOptional\n  }\n}];"
      },
