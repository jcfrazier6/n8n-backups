      "id": "build-completion-msg-01",
      "name": "Build: Completion message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        400,
        -320
      ],
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst totalCount = $('Filter: Exclude archived').all().length;\nconst failed = Array.isArray(staticData.failedFlows) ? staticData.failedFlows : [];\n\n// Build adaptive card body blocks\nconst bodyBlocks = [\n  {\n    type: 'TextBlock',\n    text: `✅ Backup completed — ${totalCount} workflows processed.`,\n    wrap: true,\n    size: 'Medium',\n    weight: 'Bolder',\n    color: 'Good'\n  }\n];\n\nif (failed.length > 0) {\n  bodyBlocks.push({\n    type: 'TextBlock',\n    text: `❌ Failed (${failed.length}):`,\n    wrap: true,\n    weight: 'Bolder',\n    color: 'Attention'\n  });\n  bodyBlocks.push({\n    type: 'TextBlock',\n    text: failed.join('\\n'),\n    wrap: true,\n    color: 'Attention'\n  });\n}\n\n// Clear failures for next run\nstaticData.failedFlows = [];\n\nconst card = {\n  type: 'AdaptiveCard',\n  '$schema': 'http://adaptivecards.io/schemas/adaptive-card.json',\n  version: '1.4',\n  body: bodyBlocks\n};\n\nreturn [{ json: { cardJson: JSON.stringify(card) } }];",
        "mode": "runOnceForAllItems"
      }
    }
