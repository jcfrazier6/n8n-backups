    {
      "id": "genPassword",
      "name": "Generate password",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        -80
      ],
      "parameters": {
        "jsCode": "const attrs = $('Build create attributes').first().json;\nconst plainPassword = `MGAtemp${new Date().getFullYear()}`;\n\nfunction encodePassword(password) {\n  let encoded = '';\n  const quoted = '\"' + password + '\"';\n  for (let i = 0; i < quoted.length; i++) {\n    encoded += String.fromCharCode(quoted.charCodeAt(i) & 0xFF, (quoted.charCodeAt(i) >>> 8) & 0xFF);\n  }\n  return encoded;\n}\n\nreturn [{ json: { ...attrs, unicodePwd: encodePassword(plainPassword) } }];"
      }
    },
