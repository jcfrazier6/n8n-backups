      {
        "id": "buildAttrs",
        "name": "Build create attributes",
        "type": "n8n-nodes-base.code",
        "typeVersion": 2,
        "position": [
          224,
          0
        ],
        "parameters": {
          "jsCode": "const item = $input.first().json;\nconst sAMAccountName = String(item.sAMAccountName || '').trim();\nconst firstName = String(item.firstName || '').trim();\nconst lastName = String(item.lastName || '').trim();\nconst jobTitle = String(item.jobTitle || '').trim();\nconst studioRaw = String(item.studioRaw || '').trim();\nconst groups = Array.isArray(item.groups) ? item.groups : (item.groups ? [item.groups] : []);\nconst empId = String(item.empId || '').trim();\nconst phoneExt = String(item.phoneExt || '').trim();\nconst credentials = String(item.credentials || '').trim();\nconst homeFolder = !!item.homeFolder;\n\nif (!sAMAccountName) throw new Error('sAMAccountName is required to create a user.');\nif (!firstName) throw new Error('First Name is required to create a user.');\nif (!lastName) throw new Error('Last Name is required to create a user.');\nif (!studioRaw) throw new Error('Studio is required to create a new account (needed to place it in the correct OU).');\n\nconst delimiter = studioRaw.includes(' ~~ ') ? ' ~~ ' : ' | ';\nconst parts = studioRaw.split(delimiter).map(s => s.trim());\nconst labelPart = parts[0] || '';\nconst street = parts[1] || '';\nconst state = parts[3] || '';\nconst zip = parts[4] || '';\nconst phone = parts[5] || '';\n\nconst dashIdx = labelPart.indexOf(' — ');\nconst company = dashIdx !== -1 ? labelPart.substring(0, dashIdx).trim() : labelPart.trim();\nconst city = dashIdx !== -1 ? labelPart.substring(dashIdx + 3).trim() : '';\n\nif (!company) throw new Error(`Could not parse company from Studio value: ${studioRaw}`);\nif (!city) throw new Error(`Could not parse city from Studio value: ${studioRaw}`);\n\nconst ouCity = city.replace(/[-\\s]/g, '');\nconst displayName = `${firstName} ${lastName}`;\nconst cn = displayName;\nconst dn = `CN=${cn},OU=${ouCity},OU=${company},OU=MGA USERS,DC=MGA,DC=com`;\nconst userPrincipalName = `${sAMAccountName}@michaelgraves.com`;\nconst mail = `${sAMAccountName}@michaelgraves.com`;\n\nconst optionalFields = {};\nif (empId) optionalFields.pager = empId;\nif (phoneExt) optionalFields.ipPhone = phoneExt;\nif (credentials) optionalFields.info = credentials;\nif (homeFolder) {\n  const bs = String.fromCharCode(92);\n  optionalFields.homeDrive = 'Z:';\n  optionalFields.homeDirectory = bs + bs + 'mga.com' + bs + 'mga_files' + bs + 'scans' + bs + sAMAccountName;\n}\n\nconst groupDns = groups.map(g => `CN=${g},OU=Security Groups,DC=MGA,DC=com`);\n\nconst optionalReplace = [];\nif (jobTitle) optionalReplace.push({ id: 'title', value: jobTitle });\nif (optionalFields.pager) optionalReplace.push({ id: 'pager', value: optionalFields.pager });\nif (optionalFields.ipPhone) optionalReplace.push({ id: 'ipPhone', value: optionalFields.ipPhone });\nif (optionalFields.info) optionalReplace.push({ id: 'info', value: optionalFields.info });\nif (optionalFields.homeDrive) optionalReplace.push({ id: 'homeDrive', value: optionalFields.homeDrive });\nif (optionalFields.homeDirectory) optionalReplace.push({ id: 'homeDirectory', value: optionalFields.homeDirectory });\n\nreturn [{ json: {\n  sAMAccountName, dn, displayName, givenName: firstName, sn: lastName, cn,\n  title: jobTitle, company, streetAddress: street, l: city, st: state,\n  postalCode: zip, telephoneNumber: phone, userPrincipalName, mail,\n  groupDns, optionalReplace, ...optionalFields\n} }];"
        }
      },
